# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com

# GitHub API Configuration
GITHUB_TOKEN=your_github_token_here

# OpenAlex API Configuration
OPENALEX_API_KEY=your_openalex_api_key_here
OPENALEX_EMAIL=your_email@example.com

# Server Configuration
PORT=3000

# Admin API Configuration
ADMIN_SECRET=replace_with_a_long_random_admin_secret

# Agent Runtime Configuration
# api keeps the existing HTTP LLM path. claude-code routes LLM-heavy calls
# through a Claude Code-compatible CLI and falls back to API by default.
TERUVION_AGENT_PROVIDER=api
TERUVION_AGENT_FALLBACK_TO_API=true
TERUVION_AGENT_COMMAND=claude
TERUVION_AGENT_ARGS=-p --dangerously-skip-permissions
TERUVION_AGENT_PROMPT_MODE=argument
TERUVION_AGENT_TIMEOUT=300000

# Debug/test only. Default behavior is LLM-enabled; set this to true only when
# isolating connector, sampling, map, or UI behavior from long LLM extraction.
TERUVION_DISABLE_LLM=false

# Frontend Configuration
NEXT_PUBLIC_API_BASE=https://api.teruvion.com
